# mikiclaw Configuration
# Copy to .env and fill in your values

# ============================================
# REQUIRED: Basic Configuration
# ============================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# ============================================
# AI Provider Configuration (choose one or more)
# ============================================

# --- Anthropic (Claude) ---
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Kimi (Moonshot) ---
# Get from: https://platform.moonshot.ai/
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.5

# --- MiniMax ---
# Get from: https://platform.minimax.io/
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_MODEL=MiniMax-M2.5

# --- Local LLM ---
# For OpenAI-compatible local servers
LOCAL_BASE_URL=http://localhost:8000/v1
LOCAL_API_KEY=not-needed
LOCAL_MODEL=local-model

# ============================================
# AI Routing & Strategy
# ============================================

# Primary AI provider (anthropic, openai, kimi, minimax, local)
AI_PROVIDER=anthropic

# AI model to use (overrides provider-specific model)
AI_MODEL=

# Enable provider routing with fallback
AI_ROUTING_ENABLED=true
AI_ROUTING_STRATEGY=balanced  # quality-first, speed-first, cost-first, balanced

# ============================================
# Channel Configuration
# ============================================

# --- Discord ---
# Get from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_GUILDS=
DISCORD_ALLOWED_CHANNELS=

# --- Slack ---
# Get from: https://api.slack.com/apps
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ALLOWED_CHANNELS=

# --- WebChat ---
WEBCHAT_ENABLED=true
WEBCHAT_PORT=18791
WEBCHAT_BIND_ADDRESS=127.0.0.1

# Default channel (telegram, discord, slack, webchat)
CHANNELS_DEFAULT=telegram
CHANNELS_ENABLED=telegram

# ============================================
# Session & Memory
# ============================================

# Session mode: main, per-peer, per-channel, per-account-channel
SESSION_MODE=main
SESSION_MAX_CONTEXT_MESSAGES=40

# Memory configuration
MEMORY_PER_USER_ENTRY_CAP=500
MEMORY_MAX_CONNECTED_CONTEXT_ENTRIES=8
MEMORY_SEMANTIC_MIN_SIMILARITY=0.75

# ============================================
# Security & Rate Limiting
# ============================================

# Encrypt credentials in config file
SECURITY_ENCRYPT_CREDENTIALS=true

# Tool policy: allow-all, block-destructive, allowlist-only
SECURITY_TOOL_POLICY=allowlist-only

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=20

# ============================================
# Webhooks & Automation
# ============================================

# Webhook server
WEBHOOKS_ENABLED=false
WEBHOOKS_PORT=18791
WEBHOOKS_SECRET=
WEBHOOKS_MAX_PAYLOAD_BYTES=1048576
WEBHOOKS_RATE_LIMIT_PER_MINUTE=60

# Automation workflows
AUTOMATION_ENABLED=false

# ============================================
# Heartbeat & Scheduled Tasks
# ============================================

HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_MINUTES=30

# ============================================
# Skills System
# ============================================

SKILLS_AUTO_UPDATE=true

# ============================================
# Workspace
# ============================================

# Workspace path (default: ~/.mikiclaw/workspace)
WORKSPACE_PATH=

# ============================================
# Logging & Debugging
# ============================================

# Log level: debug, info, warn, error
LOGGING_LEVEL=info

# ============================================
# Advanced Configuration
# ============================================

# NODE_ENV: production, development
NODE_ENV=production

# Node.js options
NODE_OPTIONS=--max-old-space-size=4096

# ============================================
# Notes:
# ============================================
# 1. Only TELEGRAM_BOT_TOKEN and one AI provider API key are required to start
# 2. Most settings can also be configured via the interactive setup wizard: npm run setup
# 3. For production, use config.json instead of .env for better security
# 4. Environment variables override config.json values